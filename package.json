{
  "name": "desktop-go",
  "version": "0.1.0",
  "description": "Check if your Expo app is live, then open it.",
  "main": "main.js",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^31.2.1"
  },
  "build": {
    "appId": "com.desktopgo.app",
    "productName": "Desktop Go",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!release/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
